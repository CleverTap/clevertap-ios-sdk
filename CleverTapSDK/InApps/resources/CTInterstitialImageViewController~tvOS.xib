<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<document type="com.apple.InterfaceBuilder.AppleTV.XIB" version="3.0" toolsVersion="13142" targetRuntime="AppleTV" propertyAccessControl="none" useAutolayout="YES" useTraitCollections="YES" useSafeAreas="YES" colorMatched="YES">
    <dependencies>
        <plugIn identifier="com.apple.InterfaceBuilder.IBCocoaTouchPlugin" version="12042"/>
        <capability name="Safe area layout guides" minToolsVersion="9.0"/>
        <capability name="documents saved in the Xcode 8 format" minToolsVersion="8.0"/>
    </dependencies>
    <objects>
        <placeholder placeholderIdentifier="IBFilesOwner" id="-1" userLabel="File's Owner" customClass="CTInterstitialImageViewController">
            <connections>
                <outlet property="closeButton" destination="oVZ-LM-h3L" id="iimg-close-out"/>
                <outlet property="containerView" destination="nQY-F6-LpS" id="iimg-cont-out"/>
                <outlet property="imageView" destination="BGP-VZ-XNs" id="iimg-img-out"/>
                <outlet property="view" destination="iN0-l3-epB" id="iimg-view-out"/>
            </connections>
        </placeholder>
        <placeholder placeholderIdentifier="IBFirstResponder" id="-2" customClass="UIResponder"/>
        <!-- Root view: 1920×1080, clear, CTInAppPassThroughView -->
        <view contentMode="scaleToFill" id="iN0-l3-epB" customClass="CTInAppPassThroughView">
            <rect key="frame" x="0.0" y="0.0" width="1920" height="1080"/>
            <autoresizingMask key="autoresizingMask" widthSizable="YES" heightSizable="YES"/>
            <subviews>
                <!-- containerView: centered card 1344×760 (cX=288, cY=160); code overrides via viewWillLayoutSubviews -->
                <view contentMode="scaleToFill" translatesAutoresizingMaskIntoConstraints="NO" id="nQY-F6-LpS">
                    <rect key="frame" x="288" y="160" width="1344" height="760"/>
                    <subviews>
                        <!-- imageView: fills entire containerView -->
                        <imageView userInteractionEnabled="NO" contentMode="scaleAspectFill" horizontalHuggingPriority="251" verticalHuggingPriority="251" translatesAutoresizingMaskIntoConstraints="NO" id="BGP-VZ-XNs">
                            <rect key="frame" x="0.0" y="0.0" width="1344" height="760"/>
                            <accessibility key="accessibilityConfiguration" label="InApp Image">
                                <bool key="isElement" value="YES"/>
                            </accessibility>
                        </imageView>
                    </subviews>
                    <color key="backgroundColor" white="1" alpha="1" colorSpace="custom" customColorSpace="genericGamma22GrayColorSpace"/>
                    <constraints>
                        <constraint firstItem="BGP-VZ-XNs" firstAttribute="top" secondItem="nQY-F6-LpS" secondAttribute="top" id="iimg-img-top"/>
                        <constraint firstItem="BGP-VZ-XNs" firstAttribute="leading" secondItem="nQY-F6-LpS" secondAttribute="leading" id="iimg-img-lead"/>
                        <constraint firstAttribute="trailing" secondItem="BGP-VZ-XNs" secondAttribute="trailing" id="iimg-img-trail"/>
                        <constraint firstAttribute="bottom" secondItem="BGP-VZ-XNs" secondAttribute="bottom" id="iimg-img-bot"/>
                    </constraints>
                </view>
                <!-- closeButton: 44×44 CTDismissButton, overlaps top-right of containerView by 15pt -->
                <button opaque="NO" contentMode="scaleToFill" contentHorizontalAlignment="center" contentVerticalAlignment="center" buttonType="custom" lineBreakMode="middleTruncation" translatesAutoresizingMaskIntoConstraints="NO" id="oVZ-LM-h3L" customClass="CTDismissButton">
                    <rect key="frame" x="1617" y="145" width="44" height="44"/>
                    <constraints>
                        <constraint firstAttribute="width" constant="44" id="iimg-close-w"/>
                        <constraint firstAttribute="height" constant="44" id="iimg-close-h"/>
                    </constraints>
                    <connections>
                        <action selector="closeButtonTapped:" destination="-1" eventType="touchUpInside" id="iimg-close-action"/>
                    </connections>
                </button>
            </subviews>
            <color key="backgroundColor" red="0" green="0" blue="0" alpha="0" colorSpace="custom" customColorSpace="sRGB"/>
            <viewLayoutGuide key="safeArea" id="iimg-safe"/>
            <constraints>
                <!-- containerView: centered; priority 750 so code-applied frame wins -->
                <constraint firstItem="nQY-F6-LpS" firstAttribute="centerX" secondItem="iN0-l3-epB" secondAttribute="centerX" id="iimg-cont-cx"/>
                <constraint firstItem="nQY-F6-LpS" firstAttribute="centerY" secondItem="iN0-l3-epB" secondAttribute="centerY" priority="750" id="iimg-cont-cy"/>
                <!-- closeButton: overlaps top-right of containerView by 15pt -->
                <constraint firstItem="oVZ-LM-h3L" firstAttribute="top" secondItem="nQY-F6-LpS" secondAttribute="top" constant="-15" id="iimg-close-top"/>
                <constraint firstItem="oVZ-LM-h3L" firstAttribute="leading" secondItem="nQY-F6-LpS" secondAttribute="trailing" constant="-15" id="iimg-close-lead"/>
            </constraints>
            <point key="canvasLocation" x="0.0" y="0.0"/>
        </view>
    </objects>
</document>
