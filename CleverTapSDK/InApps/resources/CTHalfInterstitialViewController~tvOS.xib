<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<document type="com.apple.InterfaceBuilder.AppleTV.XIB" version="3.0" toolsVersion="13142" targetRuntime="AppleTV" propertyAccessControl="none" useAutolayout="YES" useTraitCollections="YES" useSafeAreas="YES" colorMatched="YES">
    <dependencies>
        <plugIn identifier="com.apple.InterfaceBuilder.IBCocoaTouchPlugin" version="12042"/>
        <capability name="Safe area layout guides" minToolsVersion="9.0"/>
        <capability name="documents saved in the Xcode 8 format" minToolsVersion="8.0"/>
    </dependencies>
    <objects>
        <placeholder placeholderIdentifier="IBFilesOwner" id="-1" userLabel="File's Owner" customClass="CTHalfInterstitialViewController">
            <connections>
                <outlet property="bodyLabel" destination="5Aa-EQ-bsO" id="hlfint-body-out"/>
                <outlet property="buttonsContainer" destination="d7k-CL-Tei" id="hlfint-btns-out"/>
                <outlet property="closeButton" destination="IFj-b4-6aW" id="hlfint-close-out"/>
                <outlet property="containerView" destination="LY5-wo-awx" id="hlfint-cont-out"/>
                <outlet property="firstButton" destination="pHu-WW-v32" id="hlfint-btn1-out"/>
                <outlet property="imageView" destination="WxJ-Da-fBw" id="hlfint-img-out"/>
                <outlet property="secondButton" destination="slm-M2-DMb" id="hlfint-btn2-out"/>
                <outlet property="secondButtonContainer" destination="8dS-Uj-jKx" id="hlfint-btn2c-out"/>
                <outlet property="titleLabel" destination="Fxo-Hb-25n" id="hlfint-title-out"/>
                <outlet property="view" destination="iN0-l3-epB" id="hlfint-view-out"/>
            </connections>
        </placeholder>
        <placeholder placeholderIdentifier="IBFirstResponder" id="-2" customClass="UIResponder"/>
        <view contentMode="scaleToFill" id="iN0-l3-epB" customClass="CTInAppPassThroughView">
            <rect key="frame" x="0.0" y="0.0" width="1920" height="1080"/>
            <autoresizingMask key="autoresizingMask" widthSizable="YES" heightSizable="YES"/>
            <subviews>
                <!-- containerView: centered card 1344×760, code overrides frame in viewWillLayoutSubviews -->
                <view contentMode="scaleToFill" translatesAutoresizingMaskIntoConstraints="NO" id="LY5-wo-awx">
                    <rect key="frame" x="288" y="160" width="1344" height="760"/>
                    <subviews>
                        <!-- imageView: fills containerView background -->
                        <imageView userInteractionEnabled="NO" contentMode="scaleAspectFill" horizontalHuggingPriority="251" verticalHuggingPriority="251" translatesAutoresizingMaskIntoConstraints="NO" id="WxJ-Da-fBw">
                            <rect key="frame" x="0.0" y="0.0" width="1344" height="760"/>
                            <accessibility key="accessibilityConfiguration" label="InApp Image">
                                <bool key="isElement" value="YES"/>
                            </accessibility>
                        </imageView>
                        <!-- titleLabel: top 40pt, inset 80pt each side -->
                        <label opaque="NO" userInteractionEnabled="NO" contentMode="left" horizontalHuggingPriority="251" verticalHuggingPriority="251" verticalCompressionResistancePriority="751" text="Title" textAlignment="center" lineBreakMode="tailTruncation" baselineAdjustment="alignBaselines" adjustsFontSizeToFit="NO" translatesAutoresizingMaskIntoConstraints="NO" id="Fxo-Hb-25n">
                            <rect key="frame" x="80" y="40" width="1184" height="42"/>
                            <fontDescription key="fontDescription" type="boldSystem" pointSize="36"/>
                            <nil key="textColor"/>
                            <nil key="highlightedColor"/>
                        </label>
                        <!-- bodyLabel: below titleLabel + 10pt -->
                        <label opaque="NO" userInteractionEnabled="NO" contentMode="left" horizontalHuggingPriority="251" verticalHuggingPriority="251" text="Message" textAlignment="center" lineBreakMode="tailTruncation" numberOfLines="10" baselineAdjustment="alignBaselines" adjustsFontSizeToFit="NO" translatesAutoresizingMaskIntoConstraints="NO" id="5Aa-EQ-bsO">
                            <rect key="frame" x="80" y="92" width="1184" height="34"/>
                            <fontDescription key="fontDescription" type="system" pointSize="28"/>
                            <nil key="textColor"/>
                            <nil key="highlightedColor"/>
                        </label>
                        <!-- buttonsContainer: bottom-inset 20pt, horizontal inset 160pt, height 66pt -->
                        <view contentMode="scaleToFill" translatesAutoresizingMaskIntoConstraints="NO" id="d7k-CL-Tei">
                            <rect key="frame" x="160" y="674" width="1024" height="66"/>
                            <subviews>
                                <button opaque="NO" contentMode="scaleToFill" contentHorizontalAlignment="center" contentVerticalAlignment="center" buttonType="system" lineBreakMode="middleTruncation" translatesAutoresizingMaskIntoConstraints="NO" id="pHu-WW-v32">
                                    <rect key="frame" x="0.0" y="0.0" width="492" height="66"/>
                                    <constraints>
                                        <constraint firstAttribute="height" constant="66" id="hlfint-btn1-h"/>
                                    </constraints>
                                    <fontDescription key="fontDescription" type="system" pointSize="28"/>
                                    <state key="normal" title="Button"/>
                                </button>
                                <view contentMode="scaleToFill" horizontalCompressionResistancePriority="749" translatesAutoresizingMaskIntoConstraints="NO" id="8dS-Uj-jKx">
                                    <rect key="frame" x="492" y="0.0" width="532" height="66"/>
                                    <subviews>
                                        <button opaque="NO" contentMode="scaleToFill" contentHorizontalAlignment="center" contentVerticalAlignment="center" buttonType="system" lineBreakMode="middleTruncation" translatesAutoresizingMaskIntoConstraints="NO" id="slm-M2-DMb">
                                            <rect key="frame" x="40" y="0.0" width="492" height="66"/>
                                            <fontDescription key="fontDescription" type="system" pointSize="28"/>
                                            <state key="normal" title="Button"/>
                                        </button>
                                    </subviews>
                                    <color key="backgroundColor" white="0.0" alpha="0.0" colorSpace="custom" customColorSpace="genericGamma22GrayColorSpace"/>
                                    <constraints>
                                        <constraint firstAttribute="bottom" secondItem="slm-M2-DMb" secondAttribute="bottom" id="hlfint-btn2-bot"/>
                                        <constraint firstAttribute="trailing" secondItem="slm-M2-DMb" secondAttribute="trailing" id="hlfint-btn2-trail"/>
                                        <constraint firstItem="slm-M2-DMb" firstAttribute="top" secondItem="8dS-Uj-jKx" secondAttribute="top" id="hlfint-btn2-top"/>
                                        <constraint firstItem="slm-M2-DMb" firstAttribute="leading" relation="lessThanOrEqual" secondItem="8dS-Uj-jKx" secondAttribute="leading" constant="40" id="hlfint-btn2-lead"/>
                                    </constraints>
                                </view>
                            </subviews>
                            <color key="backgroundColor" white="0.0" alpha="0.0" colorSpace="custom" customColorSpace="genericGamma22GrayColorSpace"/>
                            <constraints>
                                <constraint firstItem="8dS-Uj-jKx" firstAttribute="top" secondItem="d7k-CL-Tei" secondAttribute="top" id="hlfint-btn2c-top"/>
                                <constraint firstItem="slm-M2-DMb" firstAttribute="height" secondItem="pHu-WW-v32" secondAttribute="height" id="hlfint-btneq-h"/>
                                <constraint firstItem="pHu-WW-v32" firstAttribute="leading" secondItem="d7k-CL-Tei" secondAttribute="leading" id="hlfint-btn1-lead"/>
                                <constraint firstAttribute="bottom" secondItem="8dS-Uj-jKx" secondAttribute="bottom" id="hlfint-btn2c-bot"/>
                                <constraint firstAttribute="width" relation="greaterThanOrEqual" constant="250" id="hlfint-btns-minw"/>
                                <constraint firstItem="pHu-WW-v32" firstAttribute="top" secondItem="d7k-CL-Tei" secondAttribute="top" id="hlfint-btn1-top"/>
                                <constraint firstItem="slm-M2-DMb" firstAttribute="width" secondItem="pHu-WW-v32" secondAttribute="width" id="hlfint-btneq-w"/>
                                <constraint firstItem="8dS-Uj-jKx" firstAttribute="leading" secondItem="pHu-WW-v32" secondAttribute="trailing" id="hlfint-btn2c-lead"/>
                                <constraint firstAttribute="trailing" secondItem="8dS-Uj-jKx" secondAttribute="trailing" id="hlfint-btn2c-trail"/>
                            </constraints>
                        </view>
                    </subviews>
                    <color key="backgroundColor" white="1" alpha="1" colorSpace="custom" customColorSpace="genericGamma22GrayColorSpace"/>
                    <constraints>
                        <!-- imageView fills containerView -->
                        <constraint firstItem="WxJ-Da-fBw" firstAttribute="top" secondItem="LY5-wo-awx" secondAttribute="top" id="hlfint-img-top"/>
                        <constraint firstItem="WxJ-Da-fBw" firstAttribute="leading" secondItem="LY5-wo-awx" secondAttribute="leading" id="hlfint-img-lead"/>
                        <constraint firstAttribute="trailing" secondItem="WxJ-Da-fBw" secondAttribute="trailing" id="hlfint-img-trail"/>
                        <constraint firstAttribute="bottom" secondItem="WxJ-Da-fBw" secondAttribute="bottom" id="hlfint-img-bot"/>
                        <!-- titleLabel: top 40pt, inset 80pt -->
                        <constraint firstItem="Fxo-Hb-25n" firstAttribute="top" secondItem="LY5-wo-awx" secondAttribute="top" constant="40" id="hlfint-title-top"/>
                        <constraint firstItem="Fxo-Hb-25n" firstAttribute="leading" secondItem="LY5-wo-awx" secondAttribute="leading" constant="80" id="hlfint-title-lead"/>
                        <constraint firstAttribute="trailing" secondItem="Fxo-Hb-25n" secondAttribute="trailing" constant="80" id="hlfint-title-trail"/>
                        <!-- bodyLabel: below titleLabel + 10pt -->
                        <constraint firstItem="5Aa-EQ-bsO" firstAttribute="top" secondItem="Fxo-Hb-25n" secondAttribute="bottom" constant="10" id="hlfint-body-top"/>
                        <constraint firstItem="5Aa-EQ-bsO" firstAttribute="leading" secondItem="Fxo-Hb-25n" secondAttribute="leading" id="hlfint-body-lead"/>
                        <constraint firstItem="5Aa-EQ-bsO" firstAttribute="trailing" secondItem="Fxo-Hb-25n" secondAttribute="trailing" id="hlfint-body-trail"/>
                        <!-- buttonsContainer: bottom 20pt, inset 160pt -->
                        <constraint firstAttribute="bottom" secondItem="d7k-CL-Tei" secondAttribute="bottom" constant="20" id="hlfint-btns-bot"/>
                        <constraint firstItem="d7k-CL-Tei" firstAttribute="leading" secondItem="LY5-wo-awx" secondAttribute="leading" constant="160" id="hlfint-btns-lead"/>
                        <constraint firstAttribute="trailing" secondItem="d7k-CL-Tei" secondAttribute="trailing" constant="160" id="hlfint-btns-trail"/>
                    </constraints>
                </view>
                <!-- closeButton: 44×44, overlaps top-right of containerView by 15pt -->
                <button opaque="NO" contentMode="scaleToFill" contentHorizontalAlignment="center" contentVerticalAlignment="center" buttonType="custom" lineBreakMode="middleTruncation" translatesAutoresizingMaskIntoConstraints="NO" id="IFj-b4-6aW" customClass="CTDismissButton">
                    <rect key="frame" x="1617" y="145" width="44" height="44"/>
                    <constraints>
                        <constraint firstAttribute="width" constant="44" id="hlfint-close-w"/>
                        <constraint firstAttribute="height" constant="44" id="hlfint-close-h"/>
                    </constraints>
                    <connections>
                        <action selector="closeButtonTapped:" destination="-1" eventType="touchUpInside" id="hlfint-close-action"/>
                    </connections>
                </button>
            </subviews>
            <color key="backgroundColor" red="0" green="0" blue="0" alpha="0" colorSpace="custom" customColorSpace="sRGB"/>
            <viewLayoutGuide key="safeArea" id="hlfint-safe"/>
            <constraints>
                <!-- containerView: centered, priority 750 so code-applied frame wins -->
                <constraint firstItem="LY5-wo-awx" firstAttribute="centerX" secondItem="iN0-l3-epB" secondAttribute="centerX" id="hlfint-cont-cx"/>
                <constraint firstItem="LY5-wo-awx" firstAttribute="centerY" secondItem="iN0-l3-epB" secondAttribute="centerY" priority="750" id="hlfint-cont-cy"/>
                <!-- closeButton: overlaps top-right of containerView by 15pt -->
                <constraint firstItem="IFj-b4-6aW" firstAttribute="top" secondItem="LY5-wo-awx" secondAttribute="top" constant="-15" id="hlfint-close-top"/>
                <constraint firstItem="IFj-b4-6aW" firstAttribute="leading" secondItem="LY5-wo-awx" secondAttribute="trailing" constant="-15" id="hlfint-close-lead"/>
            </constraints>
            <point key="canvasLocation" x="0.0" y="0.0"/>
        </view>
    </objects>
</document>
