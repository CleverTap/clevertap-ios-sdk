<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<document type="com.apple.InterfaceBuilder.AppleTV.XIB" version="3.0" toolsVersion="13142" targetRuntime="AppleTV" propertyAccessControl="none" useAutolayout="YES" useTraitCollections="YES" useSafeAreas="YES" colorMatched="YES">
    <dependencies>
        <plugIn identifier="com.apple.InterfaceBuilder.IBCocoaTouchPlugin" version="12042"/>
        <capability name="Safe area layout guides" minToolsVersion="9.0"/>
        <capability name="documents saved in the Xcode 8 format" minToolsVersion="8.0"/>
    </dependencies>
    <objects>
        <placeholder placeholderIdentifier="IBFilesOwner" id="-1" userLabel="File's Owner" customClass="CTCoverImageViewController">
            <connections>
                <outlet property="closeButton" destination="Kkl-Fl-pWw" id="cimg-close-out"/>
                <outlet property="containerView" destination="42J-bQ-FAk" id="cimg-cont-out"/>
                <outlet property="imageView" destination="Ir7-uh-7cQ" id="cimg-img-out"/>
                <outlet property="view" destination="iN0-l3-epB" id="cimg-view-out"/>
            </connections>
        </placeholder>
        <placeholder placeholderIdentifier="IBFirstResponder" id="-2" customClass="UIResponder"/>
        <!-- Root view: 1920×1080, clear, CTInAppPassThroughView -->
        <view contentMode="scaleToFill" id="iN0-l3-epB" customClass="CTInAppPassThroughView">
            <rect key="frame" x="0.0" y="0.0" width="1920" height="1080"/>
            <autoresizingMask key="autoresizingMask" widthSizable="YES" heightSizable="YES"/>
            <subviews>
                <!-- containerView: full-screen 1920×1080; code overrides to frame-based in viewWillLayoutSubviews -->
                <view contentMode="scaleToFill" translatesAutoresizingMaskIntoConstraints="NO" id="42J-bQ-FAk">
                    <rect key="frame" x="0.0" y="0.0" width="1920" height="1080"/>
                    <subviews>
                        <!-- imageView: fills entire containerView -->
                        <imageView userInteractionEnabled="NO" contentMode="scaleAspectFill" horizontalHuggingPriority="251" verticalHuggingPriority="251" translatesAutoresizingMaskIntoConstraints="NO" id="Ir7-uh-7cQ">
                            <rect key="frame" x="0.0" y="0.0" width="1920" height="1080"/>
                            <accessibility key="accessibilityConfiguration" label="InApp Image">
                                <bool key="isElement" value="YES"/>
                            </accessibility>
                        </imageView>
                    </subviews>
                    <color key="backgroundColor" white="1" alpha="1" colorSpace="custom" customColorSpace="genericGamma22GrayColorSpace"/>
                    <constraints>
                        <constraint firstItem="Ir7-uh-7cQ" firstAttribute="top" secondItem="42J-bQ-FAk" secondAttribute="top" id="cimg-img-top"/>
                        <constraint firstItem="Ir7-uh-7cQ" firstAttribute="leading" secondItem="42J-bQ-FAk" secondAttribute="leading" id="cimg-img-lead"/>
                        <constraint firstAttribute="trailing" secondItem="Ir7-uh-7cQ" secondAttribute="trailing" id="cimg-img-trail"/>
                        <constraint firstAttribute="bottom" secondItem="Ir7-uh-7cQ" secondAttribute="bottom" id="cimg-img-bot"/>
                    </constraints>
                </view>
                <!-- closeButton: 44×44 CTDismissButton, top-right corner, 15pt from each edge -->
                <button opaque="NO" contentMode="scaleToFill" contentHorizontalAlignment="center" contentVerticalAlignment="center" buttonType="custom" lineBreakMode="middleTruncation" translatesAutoresizingMaskIntoConstraints="NO" id="Kkl-Fl-pWw" customClass="CTDismissButton">
                    <rect key="frame" x="1861" y="15" width="44" height="44"/>
                    <constraints>
                        <constraint firstAttribute="width" constant="44" id="cimg-close-w"/>
                        <constraint firstAttribute="height" constant="44" id="cimg-close-h"/>
                    </constraints>
                    <connections>
                        <action selector="closeButtonTapped:" destination="-1" eventType="touchUpInside" id="cimg-close-action"/>
                    </connections>
                </button>
            </subviews>
            <color key="backgroundColor" red="0" green="0" blue="0" alpha="0" colorSpace="custom" customColorSpace="sRGB"/>
            <viewLayoutGuide key="safeArea" id="cimg-safe"/>
            <constraints>
                <!-- containerView: fills root view; priority 750 so code-applied frame wins -->
                <constraint firstItem="42J-bQ-FAk" firstAttribute="leading" secondItem="iN0-l3-epB" secondAttribute="leading" id="cimg-cont-lead"/>
                <constraint firstItem="42J-bQ-FAk" firstAttribute="top" secondItem="iN0-l3-epB" secondAttribute="top" priority="750" id="cimg-cont-top"/>
                <constraint firstAttribute="trailing" secondItem="42J-bQ-FAk" secondAttribute="trailing" id="cimg-cont-trail"/>
                <constraint firstAttribute="bottom" secondItem="42J-bQ-FAk" secondAttribute="bottom" priority="750" id="cimg-cont-bot"/>
                <!-- closeButton: top-right of containerView, 15pt from top and trailing -->
                <constraint firstItem="Kkl-Fl-pWw" firstAttribute="top" secondItem="42J-bQ-FAk" secondAttribute="top" constant="15" id="cimg-close-top"/>
                <constraint firstAttribute="trailing" secondItem="Kkl-Fl-pWw" secondAttribute="trailing" constant="15" id="cimg-close-trail"/>
            </constraints>
            <point key="canvasLocation" x="0.0" y="0.0"/>
        </view>
    </objects>
</document>
