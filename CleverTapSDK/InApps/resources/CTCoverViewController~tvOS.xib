<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<document type="com.apple.InterfaceBuilder.AppleTV.XIB" version="3.0" toolsVersion="13142" targetRuntime="AppleTV" propertyAccessControl="none" useAutolayout="YES" useTraitCollections="YES" useSafeAreas="YES" colorMatched="YES">
    <dependencies>
        <plugIn identifier="com.apple.InterfaceBuilder.IBCocoaTouchPlugin" version="12042"/>
        <capability name="Safe area layout guides" minToolsVersion="9.0"/>
        <capability name="documents saved in the Xcode 8 format" minToolsVersion="8.0"/>
    </dependencies>
    <objects>
        <placeholder placeholderIdentifier="IBFilesOwner" id="-1" userLabel="File's Owner" customClass="CTCoverViewController">
            <connections>
                <outlet property="bodyLabel" destination="hma-rT-vS9" id="cvr-body-out"/>
                <outlet property="buttonsContainer" destination="j0u-Ro-rdY" id="cvr-btns-out"/>
                <outlet property="closeButton" destination="BUX-mq-Vxw" id="cvr-close-out"/>
                <outlet property="containerView" destination="sMo-0l-7n9" id="cvr-cont-out"/>
                <outlet property="firstButton" destination="GB4-Xh-Cug" id="cvr-btn1-out"/>
                <outlet property="imageView" destination="Fk0-A3-ZZm" id="cvr-img-out"/>
                <outlet property="secondButton" destination="1kf-eD-I1f" id="cvr-btn2-out"/>
                <outlet property="secondButtonContainer" destination="NVa-kE-vtY" id="cvr-btn2c-out"/>
                <outlet property="titleLabel" destination="up4-az-80G" id="cvr-title-out"/>
                <outlet property="view" destination="iN0-l3-epB" id="cvr-view-out"/>
            </connections>
        </placeholder>
        <placeholder placeholderIdentifier="IBFirstResponder" id="-2" customClass="UIResponder"/>
        <view contentMode="scaleToFill" id="iN0-l3-epB" customClass="CTInAppPassThroughView">
            <rect key="frame" x="0.0" y="0.0" width="1920" height="1080"/>
            <autoresizingMask key="autoresizingMask" widthSizable="YES" heightSizable="YES"/>
            <subviews>
                <!-- containerView: full-screen 1920x1080, code overrides to frame-based in viewWillLayoutSubviews -->
                <view contentMode="scaleToFill" translatesAutoresizingMaskIntoConstraints="NO" id="sMo-0l-7n9">
                    <rect key="frame" x="0.0" y="0.0" width="1920" height="1080"/>
                    <subviews>
                        <!-- imageView: fills entire containerView background -->
                        <imageView userInteractionEnabled="NO" contentMode="scaleAspectFill" horizontalHuggingPriority="251" verticalHuggingPriority="251" translatesAutoresizingMaskIntoConstraints="NO" id="Fk0-A3-ZZm">
                            <rect key="frame" x="0.0" y="0.0" width="1920" height="1080"/>
                            <accessibility key="accessibilityConfiguration" label="InApp Image">
                                <bool key="isElement" value="YES"/>
                            </accessibility>
                        </imageView>
                        <!-- titleLabel: above buttonsContainer, inset 80pt each side, 36pt bold -->
                        <label opaque="NO" userInteractionEnabled="NO" contentMode="left" horizontalHuggingPriority="251" verticalHuggingPriority="251" verticalCompressionResistancePriority="751" text="Title" textAlignment="center" lineBreakMode="tailTruncation" baselineAdjustment="alignBaselines" adjustsFontSizeToFit="NO" translatesAutoresizingMaskIntoConstraints="NO" id="up4-az-80G">
                            <rect key="frame" x="80" y="834" width="1760" height="42"/>
                            <fontDescription key="fontDescription" type="boldSystem" pointSize="36"/>
                            <nil key="textColor"/>
                            <nil key="highlightedColor"/>
                        </label>
                        <!-- bodyLabel: below titleLabel + 10pt -->
                        <label opaque="NO" userInteractionEnabled="NO" contentMode="left" horizontalHuggingPriority="251" verticalHuggingPriority="251" text="Message" textAlignment="center" lineBreakMode="tailTruncation" numberOfLines="10" baselineAdjustment="alignBaselines" adjustsFontSizeToFit="NO" translatesAutoresizingMaskIntoConstraints="NO" id="hma-rT-vS9">
                            <rect key="frame" x="80" y="886" width="1760" height="34"/>
                            <fontDescription key="fontDescription" type="system" pointSize="28"/>
                            <nil key="textColor"/>
                            <nil key="highlightedColor"/>
                        </label>
                        <!-- buttonsContainer: bottom-inset 60pt, horizontal inset 80pt, height 66pt -->
                        <view contentMode="scaleToFill" translatesAutoresizingMaskIntoConstraints="NO" id="j0u-Ro-rdY">
                            <rect key="frame" x="80" y="954" width="1760" height="66"/>
                            <subviews>
                                <button opaque="NO" contentMode="scaleToFill" contentHorizontalAlignment="center" contentVerticalAlignment="center" buttonType="system" lineBreakMode="middleTruncation" translatesAutoresizingMaskIntoConstraints="NO" id="GB4-Xh-Cug">
                                    <rect key="frame" x="0.0" y="0.0" width="855" height="66"/>
                                    <constraints>
                                        <constraint firstAttribute="height" constant="66" id="cvr-btn1-h"/>
                                    </constraints>
                                    <fontDescription key="fontDescription" type="system" pointSize="28"/>
                                    <state key="normal" title="Button"/>
                                </button>
                                <view contentMode="scaleToFill" horizontalCompressionResistancePriority="749" translatesAutoresizingMaskIntoConstraints="NO" id="NVa-kE-vtY">
                                    <rect key="frame" x="855" y="0.0" width="905" height="66"/>
                                    <subviews>
                                        <button opaque="NO" contentMode="scaleToFill" contentHorizontalAlignment="center" contentVerticalAlignment="center" buttonType="system" lineBreakMode="middleTruncation" translatesAutoresizingMaskIntoConstraints="NO" id="1kf-eD-I1f">
                                            <rect key="frame" x="40" y="0.0" width="865" height="66"/>
                                            <fontDescription key="fontDescription" type="system" pointSize="28"/>
                                            <state key="normal" title="Button"/>
                                        </button>
                                    </subviews>
                                    <color key="backgroundColor" white="0.0" alpha="0.0" colorSpace="custom" customColorSpace="genericGamma22GrayColorSpace"/>
                                    <constraints>
                                        <constraint firstAttribute="bottom" secondItem="1kf-eD-I1f" secondAttribute="bottom" id="cvr-btn2-bot"/>
                                        <constraint firstAttribute="trailing" secondItem="1kf-eD-I1f" secondAttribute="trailing" id="cvr-btn2-trail"/>
                                        <constraint firstItem="1kf-eD-I1f" firstAttribute="top" secondItem="NVa-kE-vtY" secondAttribute="top" id="cvr-btn2-top"/>
                                        <constraint firstItem="1kf-eD-I1f" firstAttribute="leading" relation="lessThanOrEqual" secondItem="NVa-kE-vtY" secondAttribute="leading" constant="40" id="cvr-btn2-lead"/>
                                    </constraints>
                                </view>
                            </subviews>
                            <color key="backgroundColor" white="0.0" alpha="0.0" colorSpace="custom" customColorSpace="genericGamma22GrayColorSpace"/>
                            <constraints>
                                <constraint firstItem="NVa-kE-vtY" firstAttribute="top" secondItem="j0u-Ro-rdY" secondAttribute="top" id="cvr-btn2c-top"/>
                                <constraint firstItem="1kf-eD-I1f" firstAttribute="height" secondItem="GB4-Xh-Cug" secondAttribute="height" id="cvr-btneq-h"/>
                                <constraint firstItem="GB4-Xh-Cug" firstAttribute="leading" secondItem="j0u-Ro-rdY" secondAttribute="leading" id="cvr-btn1-lead"/>
                                <constraint firstAttribute="bottom" secondItem="NVa-kE-vtY" secondAttribute="bottom" id="cvr-btn2c-bot"/>
                                <constraint firstAttribute="width" relation="greaterThanOrEqual" constant="250" id="cvr-btns-minw"/>
                                <constraint firstItem="GB4-Xh-Cug" firstAttribute="top" secondItem="j0u-Ro-rdY" secondAttribute="top" id="cvr-btn1-top"/>
                                <constraint firstItem="1kf-eD-I1f" firstAttribute="width" secondItem="GB4-Xh-Cug" secondAttribute="width" id="cvr-btneq-w"/>
                                <constraint firstItem="NVa-kE-vtY" firstAttribute="leading" secondItem="GB4-Xh-Cug" secondAttribute="trailing" id="cvr-btn2c-lead"/>
                                <constraint firstAttribute="trailing" secondItem="NVa-kE-vtY" secondAttribute="trailing" id="cvr-btn2c-trail"/>
                            </constraints>
                        </view>
                    </subviews>
                    <color key="backgroundColor" white="1" alpha="1" colorSpace="custom" customColorSpace="genericGamma22GrayColorSpace"/>
                    <constraints>
                        <!-- imageView fills containerView -->
                        <constraint firstItem="Fk0-A3-ZZm" firstAttribute="top" secondItem="sMo-0l-7n9" secondAttribute="top" id="cvr-img-top"/>
                        <constraint firstItem="Fk0-A3-ZZm" firstAttribute="leading" secondItem="sMo-0l-7n9" secondAttribute="leading" id="cvr-img-lead"/>
                        <constraint firstAttribute="trailing" secondItem="Fk0-A3-ZZm" secondAttribute="trailing" id="cvr-img-trail"/>
                        <constraint firstAttribute="bottom" secondItem="Fk0-A3-ZZm" secondAttribute="bottom" id="cvr-img-bot"/>
                        <!-- titleLabel: inset 80pt each side; bottom linked to bodyLabel top -->
                        <constraint firstItem="up4-az-80G" firstAttribute="leading" secondItem="sMo-0l-7n9" secondAttribute="leading" constant="80" id="cvr-title-lead"/>
                        <constraint firstAttribute="trailing" secondItem="up4-az-80G" secondAttribute="trailing" constant="80" id="cvr-title-trail"/>
                        <!-- bodyLabel: below titleLabel + 10pt, same insets -->
                        <constraint firstItem="hma-rT-vS9" firstAttribute="top" secondItem="up4-az-80G" secondAttribute="bottom" constant="10" id="cvr-body-top"/>
                        <constraint firstItem="hma-rT-vS9" firstAttribute="leading" secondItem="up4-az-80G" secondAttribute="leading" id="cvr-body-lead"/>
                        <constraint firstItem="hma-rT-vS9" firstAttribute="trailing" secondItem="up4-az-80G" secondAttribute="trailing" id="cvr-body-trail"/>
                        <!-- bodyLabel bottom to buttonsContainer top -->
                        <constraint firstItem="j0u-Ro-rdY" firstAttribute="top" secondItem="hma-rT-vS9" secondAttribute="bottom" constant="10" id="cvr-btns-top"/>
                        <!-- buttonsContainer: bottom 60pt, inset 80pt -->
                        <constraint firstAttribute="bottom" secondItem="j0u-Ro-rdY" secondAttribute="bottom" constant="60" id="cvr-btns-bot"/>
                        <constraint firstItem="j0u-Ro-rdY" firstAttribute="leading" secondItem="sMo-0l-7n9" secondAttribute="leading" constant="80" id="cvr-btns-lead"/>
                        <constraint firstAttribute="trailing" secondItem="j0u-Ro-rdY" secondAttribute="trailing" constant="80" id="cvr-btns-trail"/>
                    </constraints>
                </view>
                <!-- closeButton: 44×44, top-right corner, 15pt from top and trailing edge -->
                <button opaque="NO" contentMode="scaleToFill" contentHorizontalAlignment="center" contentVerticalAlignment="center" buttonType="custom" lineBreakMode="middleTruncation" translatesAutoresizingMaskIntoConstraints="NO" id="BUX-mq-Vxw" customClass="CTDismissButton">
                    <rect key="frame" x="1861" y="15" width="44" height="44"/>
                    <constraints>
                        <constraint firstAttribute="width" constant="44" id="cvr-close-w"/>
                        <constraint firstAttribute="height" constant="44" id="cvr-close-h"/>
                    </constraints>
                    <connections>
                        <action selector="closeButtonTapped:" destination="-1" eventType="touchUpInside" id="cvr-close-action"/>
                    </connections>
                </button>
            </subviews>
            <color key="backgroundColor" red="0" green="0" blue="0" alpha="0" colorSpace="custom" customColorSpace="sRGB"/>
            <viewLayoutGuide key="safeArea" id="cvr-safe"/>
            <constraints>
                <!-- containerView: fills root view; priority 750 so code-applied frame wins -->
                <constraint firstItem="sMo-0l-7n9" firstAttribute="leading" secondItem="iN0-l3-epB" secondAttribute="leading" id="cvr-cont-lead"/>
                <constraint firstItem="sMo-0l-7n9" firstAttribute="top" secondItem="iN0-l3-epB" secondAttribute="top" priority="750" id="cvr-cont-top"/>
                <constraint firstAttribute="trailing" secondItem="sMo-0l-7n9" secondAttribute="trailing" id="cvr-cont-trail"/>
                <constraint firstAttribute="bottom" secondItem="sMo-0l-7n9" secondAttribute="bottom" priority="750" id="cvr-cont-bot"/>
                <!-- closeButton: top-right, 15pt from top and trailing of containerView -->
                <constraint firstItem="BUX-mq-Vxw" firstAttribute="top" secondItem="sMo-0l-7n9" secondAttribute="top" constant="15" id="cvr-close-top"/>
                <constraint firstAttribute="trailing" secondItem="BUX-mq-Vxw" secondAttribute="trailing" constant="15" id="cvr-close-trail"/>
            </constraints>
            <point key="canvasLocation" x="0.0" y="0.0"/>
        </view>
    </objects>
</document>
