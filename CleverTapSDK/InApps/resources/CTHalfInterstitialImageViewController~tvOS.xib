<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<document type="com.apple.InterfaceBuilder.AppleTV.XIB" version="3.0" toolsVersion="13142" targetRuntime="AppleTV" propertyAccessControl="none" useAutolayout="YES" useTraitCollections="YES" useSafeAreas="YES" colorMatched="YES">
    <dependencies>
        <plugIn identifier="com.apple.InterfaceBuilder.IBCocoaTouchPlugin" version="12042"/>
        <capability name="Safe area layout guides" minToolsVersion="9.0"/>
        <capability name="documents saved in the Xcode 8 format" minToolsVersion="8.0"/>
    </dependencies>
    <objects>
        <placeholder placeholderIdentifier="IBFilesOwner" id="-1" userLabel="File's Owner" customClass="CTHalfInterstitialImageViewController">
            <connections>
                <outlet property="closeButton" destination="gDx-f5-IHx" id="hiimg-close-out"/>
                <outlet property="containerView" destination="jCx-HV-npw" id="hiimg-cont-out"/>
                <outlet property="imageView" destination="9Bk-0n-AkG" id="hiimg-img-out"/>
                <outlet property="view" destination="iN0-l3-epB" id="hiimg-view-out"/>
            </connections>
        </placeholder>
        <placeholder placeholderIdentifier="IBFirstResponder" id="-2" customClass="UIResponder"/>
        <!-- Root view: 1920×1080, clear, CTInAppPassThroughView -->
        <view contentMode="scaleToFill" id="iN0-l3-epB" customClass="CTInAppPassThroughView">
            <rect key="frame" x="0.0" y="0.0" width="1920" height="1080"/>
            <autoresizingMask key="autoresizingMask" widthSizable="YES" heightSizable="YES"/>
            <subviews>
                <!-- containerView: smaller centered card 960×540 (cX=480, cY=270); code overrides via viewWillLayoutSubviews -->
                <view contentMode="scaleToFill" translatesAutoresizingMaskIntoConstraints="NO" id="jCx-HV-npw">
                    <rect key="frame" x="480" y="270" width="960" height="540"/>
                    <subviews>
                        <!-- imageView: fills entire containerView -->
                        <imageView userInteractionEnabled="NO" contentMode="scaleAspectFill" horizontalHuggingPriority="251" verticalHuggingPriority="251" translatesAutoresizingMaskIntoConstraints="NO" id="9Bk-0n-AkG">
                            <rect key="frame" x="0.0" y="0.0" width="960" height="540"/>
                            <accessibility key="accessibilityConfiguration" label="InApp Image">
                                <bool key="isElement" value="YES"/>
                            </accessibility>
                        </imageView>
                    </subviews>
                    <color key="backgroundColor" white="1" alpha="1" colorSpace="custom" customColorSpace="genericGamma22GrayColorSpace"/>
                    <constraints>
                        <constraint firstItem="9Bk-0n-AkG" firstAttribute="top" secondItem="jCx-HV-npw" secondAttribute="top" id="hiimg-img-top"/>
                        <constraint firstItem="9Bk-0n-AkG" firstAttribute="leading" secondItem="jCx-HV-npw" secondAttribute="leading" id="hiimg-img-lead"/>
                        <constraint firstAttribute="trailing" secondItem="9Bk-0n-AkG" secondAttribute="trailing" id="hiimg-img-trail"/>
                        <constraint firstAttribute="bottom" secondItem="9Bk-0n-AkG" secondAttribute="bottom" id="hiimg-img-bot"/>
                    </constraints>
                </view>
                <!-- closeButton: 44×44 CTDismissButton, overlaps top-right of containerView by 15pt -->
                <button opaque="NO" contentMode="scaleToFill" contentHorizontalAlignment="center" contentVerticalAlignment="center" buttonType="custom" lineBreakMode="middleTruncation" translatesAutoresizingMaskIntoConstraints="NO" id="gDx-f5-IHx" customClass="CTDismissButton">
                    <rect key="frame" x="1425" y="255" width="44" height="44"/>
                    <constraints>
                        <constraint firstAttribute="width" constant="44" id="hiimg-close-w"/>
                        <constraint firstAttribute="height" constant="44" id="hiimg-close-h"/>
                    </constraints>
                    <connections>
                        <action selector="closeButtonTapped:" destination="-1" eventType="touchUpInside" id="hiimg-close-action"/>
                    </connections>
                </button>
            </subviews>
            <color key="backgroundColor" red="0" green="0" blue="0" alpha="0" colorSpace="custom" customColorSpace="sRGB"/>
            <viewLayoutGuide key="safeArea" id="hiimg-safe"/>
            <constraints>
                <!-- containerView: centered; priority 750 so code-applied frame wins -->
                <constraint firstItem="jCx-HV-npw" firstAttribute="centerX" secondItem="iN0-l3-epB" secondAttribute="centerX" id="hiimg-cont-cx"/>
                <constraint firstItem="jCx-HV-npw" firstAttribute="centerY" secondItem="iN0-l3-epB" secondAttribute="centerY" priority="750" id="hiimg-cont-cy"/>
                <!-- closeButton: overlaps top-right of containerView by 15pt -->
                <constraint firstItem="gDx-f5-IHx" firstAttribute="top" secondItem="jCx-HV-npw" secondAttribute="top" constant="-15" id="hiimg-close-top"/>
                <constraint firstItem="gDx-f5-IHx" firstAttribute="leading" secondItem="jCx-HV-npw" secondAttribute="trailing" constant="-15" id="hiimg-close-lead"/>
            </constraints>
            <point key="canvasLocation" x="0.0" y="0.0"/>
        </view>
    </objects>
</document>
